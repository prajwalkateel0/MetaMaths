generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  teacher
  student
}

enum SessionStatus {
  waiting
  active
  paused
  ended
}

enum SessionMode {
  live
  async
}

enum MemberStatus {
  pending
  active
  removed
}

enum QuizStatus {
  draft
  published
  archived
}

enum Difficulty {
  easy
  medium
  hard
  adaptive
}

enum QuestionType {
  mcq
  true_false
  numeric
  short_answer
  fill_blank
}

enum SourceType {
  csv_upload
  api_riot
  api_opendota
  api_pandascore
  google_drive
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  role          Role
  displayName   String
  avatarUrl     String?
  emailVerified Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  refreshTokens    RefreshToken[]
  classrooms       Classroom[]      @relation("TeacherClassrooms")
  memberships      ClassroomMember[]
  datasets         Dataset[]
  charts           Chart[]
  quizzes          Quiz[]
  teacherSessions  Session[]        @relation("TeacherSessions")
  answers          Answer[]
  notifications    Notification[]
  auditLogs        AuditLog[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ip        String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Classroom {
  id               String   @id @default(uuid())
  teacherId        String
  name             String
  description      String?
  keyStage         String?
  joinCode         String   @unique
  approvalRequired Boolean  @default(false)
  isArchived       Boolean  @default(false)
  dashboardConfig  Json?
  createdAt        DateTime @default(now())

  teacher  User              @relation("TeacherClassrooms", fields: [teacherId], references: [id])
  members  ClassroomMember[]
  sessions Session[]
  charts   ClassroomChart[]

  @@map("classrooms")
}

model ClassroomMember {
  classroomId String
  studentId   String
  status      MemberStatus @default(active)
  joinedAt    DateTime     @default(now())

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  student   User      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([classroomId, studentId])
  @@map("classroom_members")
}

model ClassroomChart {
  classroomId String
  chartId     String
  sharedAt    DateTime @default(now())

  classroom Classroom @relation(fields: [classroomId], references: [id])
  chart     Chart     @relation(fields: [chartId], references: [id])

  @@id([classroomId, chartId])
  @@map("classroom_charts")
}

model Dataset {
  id             String     @id @default(uuid())
  ownerId        String
  title          String
  description    String?
  sourceType     SourceType
  sourceMetadata Json?
  schema         Json
  rowCount       Int?
  tags           String[]
  isPublic       Boolean    @default(false)
  refreshedAt    DateTime?
  createdAt      DateTime   @default(now())

  owner User        @relation(fields: [ownerId], references: [id])
  rows  DatasetRow[]
  charts Chart[]

  @@map("datasets")
}

model DatasetRow {
  id        BigInt @id @default(autoincrement())
  datasetId String
  row       Json
  rowIndex  Int?

  dataset Dataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@index([datasetId])
  @@map("dataset_rows")
}

model Chart {
  id          String   @id @default(uuid())
  datasetId   String?
  ownerId     String
  title       String?
  chartType   String
  config      Json
  annotations Json?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())

  owner     User             @relation(fields: [ownerId], references: [id])
  dataset   Dataset?         @relation(fields: [datasetId], references: [id])
  questions Question[]
  classrooms ClassroomChart[]

  @@map("charts")
}

model Quiz {
  id         String     @id @default(uuid())
  ownerId    String
  classroomId String?
  title      String
  topic      String?
  difficulty Difficulty?
  settings   Json?
  status     QuizStatus @default(draft)
  createdAt  DateTime   @default(now())

  owner     User       @relation(fields: [ownerId], references: [id])
  questions Question[]
  sessions  Session[]

  @@map("quizzes")
}

model Question {
  id            String       @id @default(uuid())
  quizId        String
  questionType  QuestionType
  prompt        String
  options       Json?
  correctAnswer Json
  tolerance     Float?
  points        Int          @default(1)
  timeLimitSec  Int?
  dataReference Json?
  chartId       String?
  generated     Boolean      @default(false)
  generatorMeta Json?
  orderIndex    Int?

  quiz    Quiz    @relation(fields: [quizId], references: [id], onDelete: Cascade)
  chart   Chart?  @relation(fields: [chartId], references: [id])
  answers Answer[]

  @@map("questions")
}

model Session {
  id                   String        @id @default(uuid())
  classroomId          String
  quizId               String
  teacherId            String
  status               SessionStatus @default(waiting)
  mode                 SessionMode   @default(live)
  startedAt            DateTime?
  endedAt              DateTime?
  currentQuestionIndex Int           @default(0)
  state                Json?

  classroom Classroom @relation(fields: [classroomId], references: [id])
  quiz      Quiz      @relation(fields: [quizId], references: [id])
  teacher   User      @relation("TeacherSessions", fields: [teacherId], references: [id])
  answers   Answer[]

  @@map("sessions")
}

model Answer {
  id           String   @id @default(uuid())
  sessionId    String
  questionId   String
  studentId    String
  response     Json
  isCorrect    Boolean?
  pointsAwarded Int?
  timeTakenMs  Int?
  submittedAt  DateTime @default(now())

  session  Session  @relation(fields: [sessionId], references: [id])
  question Question @relation(fields: [questionId], references: [id])
  student  User     @relation(fields: [studentId], references: [id])

  @@unique([sessionId, questionId, studentId])
  @@map("answers")
}

model AuditLog {
  id         BigInt   @id @default(autoincrement())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  ip         String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  type      String
  payload   Json
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}
