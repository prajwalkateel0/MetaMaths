# Database
# Local: docker-compose Postgres. Production: Neon pooled connection string
# (Dashboard → Connection Details → check "Pooled connection"), e.g.
# postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/metamaths?sslmode=require
DATABASE_URL="postgresql://postgres:password@localhost:5432/metamaths"

# Redis
# Local: docker-compose Redis. Production: Upstash Redis (free tier) —
# use the "rediss://" TLS URL from the Upstash dashboard.
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this"
JWT_REFRESH_SECRET="your-refresh-secret-change-this"

# Server
PORT=3001
NODE_ENV=development
# Production: the deployed Vercel frontend origin, e.g. https://metamaths.vercel.app
FRONTEND_URL=http://localhost:5173

# Email (Resend or SMTP)
EMAIL_FROM="noreply@metamaths.app"
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=your-resend-api-key

# Storage (S3-compatible)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=metamaths
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# AI (Claude) — optional, enables LLM question enhancement
ANTHROPIC_API_KEY=

# Esports APIs (optional)
RIOT_API_KEY=
OPENDOTA_API_KEY=
PANDASCORE_API_KEY=

# Google Drive OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/v1/datasets/import/gdrive/callback
